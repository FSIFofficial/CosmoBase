6:[["$","title","0",{"children":"Cosmo Base 開設日決定のお知らせ | CosmoBase"}],["$","meta","1",{"name":"description","content":"宇宙コミュニティ「Cosmo Base」が、2026年4月1日に本オープンします！<br>「すべての人に宇宙と関わる“選択肢”をつくる」というミッションのもと、<br>専門知識がない方や他業界の方でも気軽に立ち寄れる「港」のような場所を目指します。<br>日々のニュースから交流まで、ここから宇宙をもっと身近なものへ。<br>4月1日、新しい宇宙との関わり方がいよいよ始まります。"}],["$","meta","2",{"property":"og:title","content":"Cosmo Base 開設日決定のお知らせ"}],["$","meta","3",{"property":"og:description","content":"宇宙コミュニティ「Cosmo Base」が、2026年4月1日に本オープンします！<br>「すべての人に宇宙と関わる“選択肢”をつくる」というミッションのもと、<br>専門知識がない方や他業界の方でも気軽に立ち寄れる「港」のような場所を目指します。<br>日々のニュースから交流まで、ここから宇宙をもっと身近なものへ。<br>4月1日、新しい宇宙との関わり方がいよいよ始まります。"}],["$","meta","4",{"property":"og:image","content":"https://fsifofficial.github.io/CosmoBase/CosmoBase/CBopen.png"}],["$","meta","5",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","6",{"name":"twitter:title","content":"Cosmo Base"}],["$","meta","7",{"name":"twitter:description","content":"宇宙を、楽しむ。CosmoBaseは宇宙に興味がある人・産業をつなぐコミュニティーです。"}],["$","meta","8",{"name":"twitter:image","content":"https://fsifofficial.github.io/CosmoBase/CosmoBase/CBopen.png"}],["$","link","9",{"rel":"icon","href":"https://fsifofficial.github.io/CosmoBase/icon.png","sizes":"192x192","type":"image/png"}],["$","link","10",{"rel":"apple-touch-icon","href":"/CosmoBase/icon.png","sizes":"180x180","type":"image/png"}],["$","$L7","11",{}]]
