{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/resources/layout,_N_T_/resources/event/layout,_N_T_/resources/event/page,_N_T_/resources/event"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/resources/event/__PAGE__",
    "/resources/event",
    "/resources",
    "/_index",
    "/_head"
  ]
}