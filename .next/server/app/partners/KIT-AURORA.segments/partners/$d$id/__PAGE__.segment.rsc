a:["$","section",null,{"className":"py-12","children":["$","div",null,{"className":"mx-auto max-w-5xl px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"mb-6 font-serif text-2xl font-bold text-[#EEEEFF]","children":"概要"}],["$","p",null,{"className":"text-lg leading-relaxed text-[#EEEEFF]/80 whitespace-pre-wrap","children":"KIT-AURORAは九州工業大学の学生が天体探査機を創るプロジェクトです。西日本の学生団体としては初めてとなるUniversity Rover Challenge決勝大会（火星ローバーの国際大会）への出場を目指しています。さらに惑星（火星）探査ローバー開発を通じ、日本の宇宙開発の発展への寄与や技術に堪能なる士君子たるエンジニアの育成も目指しています。"}]]}]}]
