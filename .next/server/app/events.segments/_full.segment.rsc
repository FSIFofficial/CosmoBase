c:[["$","title","0",{"children":"イベントカレンダー | CosmoBase"}],["$","meta","1",{"name":"description","content":"宇宙イベントをご確認いただけます。"}],["$","meta","2",{"property":"og:title","content":"イベントカレンダー | Cosmo Base"}],["$","meta","3",{"property":"og:description","content":"宇宙イベントをご確認いただけます。"}],["$","meta","4",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","5",{"name":"twitter:title","content":"Cosmo Base"}],["$","meta","6",{"name":"twitter:description","content":"宇宙を、楽しむ。CosmoBaseは宇宙に興味がある人・産業をつなぐコミュニティーです。"}],["$","link","7",{"rel":"icon","href":"https://fsifofficial.github.io/CosmoBase/icon.png","sizes":"192x192","type":"image/png"}],["$","link","8",{"rel":"apple-touch-icon","href":"/CosmoBase/icon.png","sizes":"180x180","type":"image/png"}],["$","$Le","9",{}]]
