      "destination": "/CosmoBase",
      "basePath": false,
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^/CosmoBase/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
